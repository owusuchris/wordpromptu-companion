{
  "name": "wordpromptu-companion",
  "version": "3.0.1",
  "description": "Wordpromptu Multi-Screen Companion App",
  "main": "main.js",
  "homepage": "https://wordpromptu.com",
  "author": {
    "name": "Wordpromptu",
    "email": "michseth@ghananlp.org"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.wordpromptu.companion",
    "productName": "Wordpromptu Companion",
    "files": [
      "main.js",
      "preload.js",
      "projector.html",
      "settings.html",
      "assets/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "deb",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "ws": "^8.17.0"
  }
}
